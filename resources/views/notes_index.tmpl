{{ define "notes_index.tmpl" }}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Notes</title>
    <link rel="stylesheet" href="/public/app.css">
</head>
<body>
    <div class="container wide">
        <div class="topbar">
            <h1>Notes</h1>
            <div>
                <span class="muted">{{ .user.Name }}</span>
                <form method="POST" action="/logout" style="display:inline">
                    <button type="submit">Logout</button>
                </form>
            </div>
        </div>

        <a class="btn" href="/notes/create">+ Note baru</a>

        {{ range .notes }}
        <div class="note">
            <h3>{{ .Title }}</h3>
            <p>{{ .Body }}</p>
            <div class="note-actions">
                <a class="btn" href="/notes/{{ .ID }}/edit">Edit</a>
                <form method="POST" action="/notes/{{ .ID }}/delete">
                    <button type="submit" class="btn-danger">Hapus</button>
                </form>
            </div>
        </div>
        {{ else }}
        <p class="muted">Belum ada note.</p>
        {{ end }}
    </div>
</body>
</html>
{{ end }}
